# Analyxa Configuration
# Copy this file to .env and fill in your API keys

# Required: At least one LLM provider
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Provider settings
ANALYXA_PROVIDER=anthropic    # anthropic or openai
ANALYXA_MODEL=                # Leave empty for provider default
ANALYXA_SCHEMA=universal      # Default schema

# Optional: Infrastructure
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# Optional: Features
ANALYXA_EMBEDDINGS=true       # Enable semantic embeddings
